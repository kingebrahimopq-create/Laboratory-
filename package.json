{
  "name": "mylab-lims",
  "private": true,
  "version": "2.0.0",
  "type": "module",
  "main": "electron/main.cjs",
  "description": "My Lab LIMS - Laboratory Information Management System",
  "author": "My Lab Team",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "dev": "tsx server.ts",
    "build": "vite build && esbuild server.ts --bundle --platform=node --format=cjs --packages=external --sourcemap --outfile=dist/server.cjs",
    "start": "node dist/server.cjs",
    "preview": "node dist/server.cjs",
    "clean": "rm -rf dist server.js dist-electron android ios",
    "lint": "tsc --noEmit",
    "test": "vitest run",
    "test:ui": "vitest --ui",
    "db:seed": "tsx scripts/seed-database.ts",
    "db:migrate": "tsx scripts/migrate-database.ts",
    "db:backup": "tsx scripts/backup-database.ts",
    "db:restore": "tsx scripts/restore-database.ts",
    "electron:dev": "npm run build && electron .",
    "electron:build": "npm run build && electron-builder --win",
    "android:init": "npx cap add android || true && npx cap sync android",
    "android:build": "npm run build && npm run android:init && cd android && ./gradlew assembleDebug",
    "postinstall": "npx cap sync || true"
  },
  "dependencies": {
    "@capacitor/android": "^6.0.0",
    "@capacitor/core": "^6.0.0",
    "@google/genai": "^2.4.0",
    "@tailwindcss/vite": "^4.1.14",
    "@vitejs/plugin-react": "^5.0.4",
    "clsx": "2.1.1",
    "dotenv": "^16.4.5",
    "express": "^4.21.2",
    "firebase": "^11.0.0",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "qrcode": "^1.5.4",
    "react": "^19.0.1",
    "react-dom": "^19.0.1",
    "tailwind-merge": "3.6.0",
    "vite": "^6.2.3",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@capacitor/cli": "^6.0.0",
    "@playwright/test": "1.60.0",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@types/express": "^4.17.21",
    "@types/node": "^20.14.0",
    "@types/qrcode": "^1.5.6",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "autoprefixer": "^10.4.21",
    "electron": "^32.0.0",
    "electron-builder": "^25.0.0",
    "esbuild": "^0.25.0",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.3",
    "vitest": "4.1.8"
  }
}
