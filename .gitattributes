# Text files
*.txt text
*.md text
*.json text
*.yml text
*.yaml text
*.ts text
*.tsx text
*.js text
*.jsx text
*.css text
*.scss text
*.less text
*.html text

# Binary files
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.svg binary
*.woff binary
*.woff2 binary
*.ttf binary
*.eot binary

# Line endings
*.sh text eol=lf
*.bat text eol=crlf
*.ps1 text eol=crlf
*.cmd text eol=crlf

# Diff settings
*.png diff=lfs
*.jpg diff=lfs
*.jpeg diff=lfs
*.gif diff=lfs
*.ico diff=lfs
*.svg diff=lfs
*.woff diff=lfs
*.woff2 diff=lfs
*.ttf diff=lfs
*.eot diff=lfs

# Merge drivers
*.lock merge=union
package*.json merge=union

# Language detection
*.ts linguist-language=TypeScript
*.tsx linguist-language=TypeScript
*.js linguist-language=JavaScript
*.jsx linguist-language=JavaScript
