root = true

[*]
charset = utf-8
end_of_line = lf
indent_style = space
indent_size = 2
insert_final_newline = true
trim_trailing_whitespace = true

[*.{js,jsx,ts,tsx,json,yml,yaml,md,html,css,scss,less}]
indent_size = 2

[*.{png,jpg,jpeg,gif,svg,ico,woff,woff2,ttf}]
binary = true

[Makefile]
indent_style = tab
