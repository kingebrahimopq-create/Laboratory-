# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# Google Auth Secrets
GOOGLE_CLIENT_ID="12279673341-qevn7tdgfvtr8tmr9c3kl3qdj10obk00.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="BKl7xUi_gsp9AmsmTLW5ca6vIfgFdzvbsbc1H69BppXBYpqLXwxPwPxHIs-5NzCG7iKz63pI8kHbPJ5g_aKm0rk"

# GitHub Token
GITHUB_PAT="YOUR_GITHUB_PERSONAL_ACCESS_TOKEN"

# Firebase Admin SDK Secrets
FIREBASE_PROJECT_ID="gen-lang-client-0393240619"
FIREBASE_CLIENT_EMAIL="firebase-adminsdk-fbsvc@gen-lang-client-0393240619.iam.gserviceaccount.com"
FIREBASE_PRIVATE_KEY="YOUR_PRIVATE_KEY"

# Client Firebase Configuration
VITE_FIREBASE_API_KEY=your_firebase_api_key
VITE_FIREBASE_AUTH_DOMAIN=your_firebase_auth_domain
VITE_FIREBASE_PROJECT_ID=your_firebase_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_firebase_storage_bucket
VITE_FIREBASE_MESSAGING_SENDER_ID=your_firebase_messaging_sender_id
VITE_FIREBASE_APP_ID=your_firebase_app_id
VITE_FIREBASE_MEASUREMENT_ID=your_firebase_measurement_id

# Client Google API Configuration
VITE_GOOGLE_CLIENT_ID=your_google_client_id
VITE_GOOGLE_CLIENT_SECRET=your_google_client_secret
VITE_GOOGLE_API_KEY=your_google_api_key
VITE_GOOGLE_REDIRECT_URI=http://localhost:5173/auth/callback

# Client App Configuration
VITE_APP_NAME="My Lab LIMS"
VITE_APP_VERSION=0.0.0
VITE_APP_ENV=development
VITE_API_BASE_URL=http://localhost:3000

# Client Feature Flags
VITE_ENABLE_GOOGLE_DRIVE_SYNC=true
VITE_ENABLE_GMAIL_INTEGRATION=true
VITE_ENABLE_FIREBASE_STORAGE=true

