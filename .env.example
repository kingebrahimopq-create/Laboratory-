# GEMINI_API_KEY: Required for Gemini AI API calls.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL=""

# VITE_APP_URL: Frontend accessible app URL for InAppUpdate component
VITE_APP_URL=""

# Firebase Configuration (loaded from firebase-applet-config.json)
# No additional env vars needed - Firebase config is in firebase-applet-config.json

# GitHub auto-deployment credentials
GITHUB_PAT="YOUR_GITHUB_PERSONAL_ACCESS_TOKEN"
GOOGLE_CLIENT_ID="YOUR_GOOGLE_CLIENT_ID"
GOOGLE_PROJECT_NUMBER="YOUR_GOOGLE_PROJECT_NUMBER"
